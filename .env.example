# Required
ANTHROPIC_API_KEY=sk-ant-...

# MySQL connection — individual parameters (used by the app and by dbt)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=your_user
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=your_database

# Optional — override dbt artifact paths (defaults to dbt_health_gen_ai_chat/target/)
# Only needed for local development; Docker generates them automatically at startup.
# DBT_MANIFEST_PATH=/absolute/path/to/manifest.json
# DBT_SEMANTIC_MANIFEST_PATH=/absolute/path/to/semantic_manifest.json

# Optional — Claude model to use by the web UI (defaults to claude-haiku-4-5-20251001)
# Only reasoning/thinking-capable models are supported (required by thinking={"type": "adaptive"}).
# Valid options:
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MODEL=claude-opus-4-8

# Optional — base URL the Streamlit dashboard renderer uses to reach the chat backend
# (defaults to http://localhost:8000; set to http://app:8000 in Docker)
# CHAT_API_BASE_URL=http://localhost:8000
