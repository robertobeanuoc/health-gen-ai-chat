# Required
ANTHROPIC_API_KEY=sk-ant-...
MYSQL_ALCHEMY_URI=mysql+pymysql://user:password@localhost:3306/dbname

# Optional — override dbt artifact paths (defaults to dbt_health_gen_ai_chat/target/)
# DBT_MANIFEST_PATH=/absolute/path/to/manifest.json
# DBT_SEMANTIC_MANIFEST_PATH=/absolute/path/to/semantic_manifest.json

# Optional — Claude model to use (defaults to claude-haiku-4-5-20251001)
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MODEL=claude-opus-4-8
