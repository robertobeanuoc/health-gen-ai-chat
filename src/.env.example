# Copy this file to src/.env and fill in the real values.
# src/.env is listed in .gitignore and must never be committed to the repository.

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# SQLAlchemy connection URL for MySQL
# Format: mysql+pymysql://user:password@host:port/database
MYSQL_ALCHEMY_URI=mysql+pymysql://user:password@localhost:3306/health_db

# Optional — Claude model to use (defaults to claude-sonnet-4-6)
# Only reasoning/thinking-capable models are supported (required by thinking={"type": "adaptive"}).
# Valid options:
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_MODEL=claude-opus-4-8
