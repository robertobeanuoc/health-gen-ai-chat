# Copia este fichero a src/.env y rellena los valores reales.
# El fichero src/.env está en .gitignore y nunca se sube al repositorio.

# Clave de la API de Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# URL de conexión SQLAlchemy a MySQL
# Formato: mysql+pymysql://usuario:contraseña@host:puerto/base_de_datos
MYSQL_ALCHEMY_URI=mysql+pymysql://user:password@localhost:3306/health_db
